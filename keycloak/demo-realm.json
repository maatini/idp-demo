        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "quarkus-service",
      "enabled": true,
      "bearerOnly": true,
      "webOrigins": [],
      "redirectUris": []
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "test",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    }
  ]
}
