{
  "id": "demo-realm",
  "realm": "demo-realm",
  "enabled": true,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard User Role"
      }
    ]
  },
  "groups": [],
  "clients": [
    {
      "clientId": "angular-client",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
